{
  "name": "@antdv-next/x-skill",
  "version": "0.0.2",
  "description": "CLI tool for installing AI skills to development tools like Claude, Cursor, etc.",
  "homepage": "https://github.com/antdv-next/x",
  "bugs": {
    "url": "https://github.com/antdv-next/x/issues"
  },
  "license": "MIT",
  "bin": {
    "x-skill": "dist/cli.js"
  },
  "files": [
    "skills",
    "skills-zh",
    "dist",
    ".skill.json",
    ".claude-plugin"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "type-check": "tsc --project tsconfig.json --noEmit",
    "build": "tsc --project tsconfig.build.json",
    "generate-meta": "tsx scripts/generate-meta.ts",
    "generate-version": "tsx scripts/generate-version.ts"
  },
  "dependencies": {
    "figlet": "^1.10.0",
    "ora": "^9.3.0",
    "progress": "^2.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/progress": "^2.0.7",
    "tsx": "^4.19.1"
  }
}
