{
  "name": "@antdv-next/x-markdown",
  "version": "0.0.1",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugins/Latex": {
      "types": "./dist/plugins/Latex/index.d.ts",
      "import": "./dist/plugins/Latex/index.js"
    },
    "./themes/light.css": "./src/themes/light.css",
    "./themes/dark.css": "./src/themes/dark.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "type-check": "tsc --project tsconfig.json --noEmit",
    "build": "tsc --project tsconfig.build.json"
  },
  "dependencies": {
    "dompurify": "^3.1.0",
    "katex": "^0.16.25",
    "marked": "^12.0.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5"
  },
  "peerDependencies": {
    "vue": ">=3.5.0"
  }
}
