{
  "name": "@antdv-next/x-markdown",
  "version": "0.0.2",
  "license": "MIT",
  "files": [
    "dist",
    "plugins",
    "themes"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugins/*": {
      "types": "./plugins/*/index.d.ts",
      "import": "./plugins/*/index.js"
    },
    "./themes/*.css": "./themes/*.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "type-check": "vue-tsc --project tsconfig.build.json --noEmit",
    "build": "vp build --config vite.build.config.ts && vp build --config vite.build.config.ts --mode plugins && node ./scripts/copy-themes.mjs"
  },
  "dependencies": {
    "dompurify": "^3.1.0",
    "katex": "^0.16.25",
    "marked": "^12.0.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5"
  },
  "peerDependencies": {
    "vue": ">=3.5.0"
  }
}
